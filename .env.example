# Titan V11.3 — Environment Configuration
# Copy to .env and fill in values

# API Authentication
TITAN_API_SECRET=change-me-to-a-secure-random-string

# API Port (used by workflow engine internal calls)
TITAN_API_PORT=8080

# Data paths
TITAN_DATA=/opt/titan/data

# GPU / AI
TITAN_GPU_URL=http://127.0.0.1:8765
TITAN_GPU_OLLAMA=http://127.0.0.1:11435
TITAN_AGENT_MODEL=titan-agent:7b
TITAN_SPECIALIST_MODEL=titan-specialist:7b
TITAN_VISION_MODEL=minicpm-v:8b
VASTAI_CODING_API_URL=http://1.208.108.242:23707/v1
VASTAI_CODING_MODEL=qwen2.5-coder:7b

# Cuttlefish paths (updated for actual installation)
CVD_BIN_DIR=/opt/titan/cuttlefish/cf/bin
CVD_IMAGES_DIR=/opt/titan/images
CVD_HOME_BASE=/opt/titan/cuttlefish

# Hostinger VPS API (optional — for format_vps.py)
HOSTINGER_API_TOKEN=

# Vast.ai GPU tunnel (optional)
VASTAI_HOST=185.62.108.226
VASTAI_PORT=42655
