FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    adb curl sqlite3 tesseract-ocr ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/titan

COPY server/requirements.txt /opt/titan/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY core/ /opt/titan/core/
COPY server/ /opt/titan/server/
COPY console/ /opt/titan/console/
COPY scripts/ /opt/titan/scripts/

ENV PYTHONPATH=/opt/titan/server:/opt/titan/core
ENV TITAN_DATA=/opt/titan/data
ENV TITAN_GPU_OLLAMA=http://127.0.0.1:11435

RUN mkdir -p /opt/titan/data/devices /opt/titan/data/profiles /opt/titan/data/config

EXPOSE 8080

CMD ["python3", "-m", "uvicorn", "server.titan_api:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "2", "--loop", "uvloop", "--http", "httptools"]
